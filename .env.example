# OpenShift Pipelines Skills - Environment Variables
# Copy this file to .env and fill in your values

# Jira Personal Access Token (required for /osp:map-jira-to-upstream, /osp:release-status)
# Create token at: https://issues.redhat.com/secure/ViewProfile.jspa?selectedTab=com.atlassian.pats.pats-plugin:jira-user-personal-access-tokens
JIRA_TOKEN=

# GitHub token (optional - gh CLI authentication preferred)
# If not using `gh auth login`, this increases API rate limit from 60 to 5000 requests/hour
# Create token at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Jira Cloud API Token (required for /osp:sprint-status)
# Create token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_CLOUD_EMAIL=
JIRA_CLOUD_TOKEN=
